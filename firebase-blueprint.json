{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stored user information and role",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "teacher", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "email", "role"]
    },
    "Course": {
      "title": "Course",
      "description": "Cybersecurity course metadata",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "instructorId": { "type": "string" },
        "instructorName": { "type": "string" },
        "difficulty": { "type": "string", "enum": ["Beginner", "Intermediate", "Advanced"] },
        "thumbnail": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "instructorId", "difficulty"]
    },
    "Lesson": {
      "title": "Lesson",
      "description": "Individual module within a course",
      "type": "object",
      "properties": {
        "courseId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "videoUrl": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["courseId", "title", "order"]
    },
    "Assignment": {
      "title": "Assignment",
      "description": "Lab task for students",
      "type": "object",
      "properties": {
        "courseId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" }
      },
      "required": ["courseId", "title", "dueDate"]
    },
    "Submission": {
      "title": "Submission",
      "description": "Student assignment submission",
      "type": "object",
      "properties": {
        "assignmentId": { "type": "string" },
        "studentId": { "type": "string" },
        "fileUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "graded"] },
        "grade": { "type": "string" },
        "feedback": { "type": "string" },
        "submittedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["assignmentId", "studentId", "fileUrl", "status"]
    },
    "Progress": {
      "title": "Student Progress",
      "description": "Tracking course completion for a student",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "courseId": { "type": "string" },
        "completedLessons": { "type": "array", "items": { "type": "string" } },
        "percentComplete": { "type": "number" },
        "lastAccessed": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "courseId", "percentComplete"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Primary user storage"
    },
    "/courses/{courseId}": {
      "schema": "Course",
      "description": "Course catalog"
    },
    "/courses/{courseId}/lessons/{lessonId}": {
      "schema": "Lesson",
      "description": "Lessons within a course"
    },
    "/courses/{courseId}/assignments/{assignmentId}": {
      "schema": "Assignment",
      "description": "Assignments within a course"
    },
    "/submissions/{submissionId}": {
      "schema": "Submission",
      "description": "Global submission records (secured by studentId/course context)"
    },
    "/progress/{progressId}": {
      "schema": "Progress",
      "description": "Tracking records mapping student to course"
    }
  }
}
